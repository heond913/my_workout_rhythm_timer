    <!-- Completion Tips & Encouragement -->
    <string name="squat_encouragement">¡Estímulo perfecto para la parte inferior del cuerpo! ¡Siente tus glúteos fortaleciéndose!</string>
    <string name="squat_tip1">Mantén los pies a la anchura de los hombros y asegúrate de que tus rodillas no pasen las puntas de tus pies.</string>
    <string name="squat_tip2">Presiona principalmente a través de tus talones al levantarte para dirigir la carga a tus glúteos.</string>

    <string name="lunge_encouragement">¡Equilibrio impecable! ¡Estás desarrollando simetría y fuerza en las piernas!</string>
    <string name="lunge_tip1">Mantén el pecho erguido, la columna recta y busca doblar ambas rodillas a 90 grados.</string>
    <string name="lunge_tip2">Mantén el 70% del peso en tu talón delantero para proteger las articulaciones de la rodilla.</string>

    <string name="plank_encouragement">¡Resistencia sobresaliente! ¡Tu core se está convirtiendo en una potencia de estabilidad!</string>
    <string name="plank_tip1">Mantén una línea recta desde los hombros hasta los talones, manteniendo la pelvis firme.</string>
    <string name="plank_tip2">Presiona activamente con tus codos y antebrazos para mantener los hombros estables.</string>

    <string name="other_encouragement">¡Rutina completa! ¡La consistencia es la contraseña para desbloquear el máximo rendimiento!</string>
    <string name="other_tip1">Las sesiones siempre deben comenzar con calentamiento y acabar con estiramientos de enfriamiento.</string>
    <string name="other_tip2">Escucha a tu cuerpo, mantente hidratado y adapta el esfuerzo a tu nivel de fatiga.</string>

